# ======================
# API KEYS
# ======================

FOOTBALL_DATA_API_KEY=your_key_here
ODDS_API_KEY=your_key_here

# ======================
# DATABASE
# ======================

POSTGRES_HOST=db
POSTGRES_DB=football_ai
POSTGRES_USER=admin
POSTGRES_PASSWORD=strongpassword
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

# ======================
# MODEL SETTINGS
# ======================

MODEL_RETRAIN_HOURS=6
VALUE_BET_THRESHOLD=0.05

# ======================
# LIVE SYSTEM
# ======================

LIVE_POLL_INTERVAL=30
ENABLE_LIVE_BETTING=true

# ======================
# TELEGRAM ALERTS
# ======================

TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_chat_id

# ======================
# ENVIRONMENT
# ======================

ENV=production
